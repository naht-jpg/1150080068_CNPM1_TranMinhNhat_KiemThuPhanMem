<?xml version="1.0" encoding="UTF-8"?>
<!-- testng.xml - chỉ chạy nhóm smoke -->
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SauceDemo_Smoke_Suite" verbose="1" parallel="classes" thread-count="2">
    <!-- Truyền tham số chung cho toàn bộ suite -->
    <parameter name="baseUrl" value="https://www.saucedemo.com"/>
    <parameter name="browser" value="chrome"/>

    <test name="Smoke Tests">
        <!-- Phân nhóm: chỉ chạy nhóm smoke -->
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="dtm.LoginTest"/>
            <class name="dtm.CartTest"/>
            <class name="dtm.CheckoutTest"/>
        </classes>
    </test>
</suite>
