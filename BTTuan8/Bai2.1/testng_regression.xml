<?xml version="1.0" encoding="UTF-8"?>
<!-- testng_regression.xml - chạy nhóm regression (tất cả) -->
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SauceDemo_Regression_Suite" verbose="1" parallel="classes" thread-count="2">
    <!-- Truyền tham số chung cho toàn bộ suite -->
    <parameter name="baseUrl" value="https://www.saucedemo.com"/>
    <parameter name="browser" value="chrome"/>

    <test name="Regression Tests">
        <!-- Phân nhóm: chạy nhóm regression (bao gồm tất cả test) -->
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="dtm.LoginTest"/>
            <class name="dtm.CartTest"/>
            <class name="dtm.CheckoutTest"/>
        </classes>
    </test>
</suite>
